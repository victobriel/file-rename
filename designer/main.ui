  </property>
  <property name="windowTitle">
   <string>MainWindow</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* =========================================================
   Base
   ========================================================= */
QMainWindow, QWidget#centralwidget {
    background-color: #1f2a38;
    color: #e6edf3;
    font-family: &quot;Segoe UI&quot;, &quot;Inter&quot;, &quot;Arial&quot;;
    font-size: 10pt;
}
QWidget {
    color: #e6edf3;
}
QWidget#mainColumn, QWidget#rightPanel, QWidget#leftPanel {
    background-color: #1f2a38;
    border: none;
}
QLabel {
    color: #e6edf3;
    background: transparent;
}
QLabel:disabled {
    color: #556274;
}
QLabel#heroTitle {
    color: #e6edf3;
    font-size: 28pt;
    font-weight: 700;
    padding: 0;
    margin: 0;
}
QLabel#heroSubtitle {
    color: #8b97a7;
    font-size: 10pt;
    padding: 0;
    margin: 0;
}

/* =========================================================
   Sections: card-style QGroupBox with an orange floating title
   ========================================================= */
QGroupBox {
    background-color: #232f3e;
    border: 1px solid #2a3748;
    border-radius: 12px;
    margin-top: 14px;
    padding: 20px 20px 16px 20px;
    color: #f97316;
    font-size: 10pt;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 18px;
    top: 2px;
    padding: 2px 10px;
    background-color: #1f2a38;
    color: #f97316;
    font-weight: 500;
    font-size: 10pt;
}

/* Thin divider between step cards in the left column */
QFrame#stepSeparator {
    background-color: #2a3748;
    color: #2a3748;
    max-height: 1px;
    min-height: 1px;
    border: none;
}

/* =========================================================
   Help &quot;banner&quot; reduced to a single-line text link
   ========================================================= */
QCommandLinkButton#helpButton {
    background: transparent;
    border: none;
    color: #8b97a7;
    text-align: left;
    padding: 2px 0;
    font-size: 9pt;
    text-decoration: underline;
}
QCommandLinkButton#helpButton:hover {
    color: #e6edf3;
}

/* =========================================================
   Buttons — generic secondary / ghost / primary
   ========================================================= */
QPushButton {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 6px 14px;
    min-height: 24px;
}
QPushButton:hover {
    background-color: #32415a;
}
QPushButton:pressed {
    background-color: #263345;
}
QPushButton:disabled {
    background-color: #243142;
    color: #556274;
}

/* Primary call-to-action — bright orange &quot;Rename&quot; */
QPushButton#renameButton {
    background-color: #f97316;
    color: #ffffff;
    border: 1px solid #c2410c;
    border-radius: 10px;
    padding: 0 22px;
    font-size: 11pt;
    font-weight: 700;
    min-height: 44px;
}
QPushButton#renameButton:hover {
    background-color: #fb923c;
    border-color: #c2410c;
}
QPushButton#renameButton:pressed {
    background-color: #ea580c;
}
QPushButton#renameButton:disabled {
    background-color: #6b3a1e;
    color: #cbbdb0;
    border-color: transparent;
}

/* Folder picker — compact icon square */
QPushButton#openFolderButton {
    background-color: #2a3748;
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 0;
    min-width: 40px;
    min-height: 40px;
    max-width: 40px;
    max-height: 40px;
}
QPushButton#openFolderButton:hover {
    background-color: #32415a;
}

/* Specific-files icon buttons */
QPushButton#specificFilesAddButton,
QPushButton#specificFilesClearButton {
    background-color: #2a3748;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 0;
    min-width: 32px;
    min-height: 32px;
    max-width: 32px;
    max-height: 32px;
}
QPushButton#specificFilesAddButton:hover,
QPushButton#specificFilesClearButton:hover {
    background-color: #32415a;
}
QPushButton#specificFilesAddButton:disabled,
QPushButton#specificFilesClearButton:disabled {
    background-color: #243142;
}

/* =========================================================
   Inputs — line edits, combos, spin boxes
   ========================================================= */
QLineEdit {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 6px 10px;
    selection-background-color: #f97316;
    selection-color: #ffffff;
    min-height: 24px;
}
QLineEdit:focus {
    border: 1px solid #f97316;
    background-color: #2a3748;
}
QLineEdit:disabled {
    background-color: #243142;
    color: #556274;
}

QComboBox {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 6px 12px;
    min-height: 24px;
}
QComboBox:focus {
    border: 1px solid #f97316;
}
QComboBox:disabled {
    background-color: #243142;
    color: #556274;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox::down-arrow {
    image: none;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #8b97a7;
    margin-right: 8px;
}
QComboBox QAbstractItemView {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid #2a3748;
    border-radius: 6px;
    padding: 4px;
    selection-background-color: #f97316;
    selection-color: #ffffff;
    outline: 0;
}

QSpinBox {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 6px 8px;
    min-height: 24px;
}
QSpinBox:focus {
    border: 1px solid #f97316;
}
QSpinBox:disabled {
    background-color: #243142;
    color: #556274;
}
QSpinBox::up-button, QSpinBox::down-button {
    background: transparent;
    border: none;
    width: 16px;
}
QSpinBox::up-arrow {
    image: none;
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #8b97a7;
}
QSpinBox::down-arrow {
    image: none;
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #8b97a7;
}

/* =========================================================
   Check boxes
   ========================================================= */
QCheckBox {
    color: #e6edf3;
    spacing: 10px;
    padding: 3px 0;
    background: transparent;
}
QCheckBox:disabled {
    color: #556274;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #556274;
    border-radius: 4px;
    background: transparent;
}
QCheckBox::indicator:hover {
    border-color: #f97316;
}
QCheckBox::indicator:checked {
    background-color: #f97316;
    border-color: #f97316;
    image: none;
}
QCheckBox::indicator:checked:hover {
    background-color: #fb923c;
    border-color: #fb923c;
}
QCheckBox::indicator:disabled {
    border-color: #2a3748;
    background: transparent;
}

/* =========================================================
   List widgets (common + specific file filters)
   ========================================================= */
QListWidget {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 4px;
    outline: 0;
}
QListWidget::item {
    padding: 6px 8px;
    border-radius: 6px;
}
QListWidget::item:hover {
    background-color: #32415a;
}
QListWidget::item:selected {
    background-color: #f97316;
    color: #ffffff;
}
QListWidget:disabled {
    background-color: #243142;
    color: #556274;
}

/* =========================================================
   Preview table — maximal minimalism
   ========================================================= */
QTableWidget#filesList {
    background-color: transparent;
    alternate-background-color: #243142;
    color: #e6edf3;
    gridline-color: transparent;
    border: none;
    selection-background-color: #f97316;
    selection-color: #ffffff;
    outline: 0;
}
QTableWidget#filesList::item {
    padding: 6px 8px;
    border: none;
}
QTableWidget#filesList::item:hover {
    background-color: #2a3748;
}
QHeaderView {
    background: transparent;
    border: none;
}
QHeaderView::section {
    background-color: transparent;
    color: #8b97a7;
    padding: 10px 8px 8px 8px;
    border: none;
    border-bottom: 1px solid #2a3748;
    font-size: 9pt;
    font-weight: 600;
}
QTableCornerButton::section {
    background: transparent;
    border: none;
    border-bottom: 1px solid #2a3748;
}

/* =========================================================
   Status bar + progress bar
   ========================================================= */
QStatusBar {
    background: transparent;
    color: #8b97a7;
    border: none;
    padding: 4px 16px;
    font-size: 9pt;
}
QStatusBar::item {
    border: none;
}
QProgressBar {
    background-color: #2a3748;
    color: transparent;
    border: none;
    border-radius: 3px;
    max-height: 6px;
    min-height: 6px;
    text-align: center;
}
QProgressBar::chunk {
    background-color: #f97316;
    border-radius: 3px;
}

/* =========================================================
   Menu bar / menus — very quiet
   ========================================================= */
QMenuBar {
    background: transparent;
    color: #8b97a7;
    border: none;
    padding: 10px 40px;
    font-size: 10pt;
}
QMenuBar::item {
    background: transparent;
    padding: 8px 18px;
    border-radius: 4px;
}
QMenuBar::item:selected {
    background: transparent;
    color: #f97316;
}
QMenuBar::item:pressed {
    background: transparent;
    color: #ea580c;
}
QMenu {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid #2a3748;
    border-radius: 6px;
    padding: 6px;
}
QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}
QMenu::item:selected {
    background-color: #f97316;
    color: #ffffff;
}
QMenu::separator {
    height: 1px;
    background: #2a3748;
    margin: 4px 8px;
}

/* =========================================================
   Separator frame (kept for backwards compat; now invisible)
   ========================================================= */
QFrame#separator {
    background-color: transparent;
    color: transparent;
    max-height: 1px;
    border: none;
}

/* =========================================================
   Scroll areas &amp; scroll bars — 8px thin
   ========================================================= */
QScrollArea {
    background: transparent;
    border: none;
}
QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0;
    border: none;
}
QScrollBar::handle:vertical {
    background: #2a3748;
    border-radius: 4px;
    min-height: 24px;
    margin: 2px;
}
QScrollBar::handle:vertical:hover {
    background: #556274;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}
QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0;
    border: none;
}
QScrollBar::handle:horizontal {
    background: #2a3748;
    border-radius: 4px;
    min-width: 24px;
    margin: 2px;
}
QScrollBar::handle:horizontal:hover {
    background: #556274;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* =========================================================
   Splitter — invisible 1px handle
   ========================================================= */
QSplitter::handle {
    background: transparent;
}
QSplitter::handle:horizontal {
    width: 1px;
}
QSplitter::handle:horizontal:hover {
    background: #2a3748;
}

/* =========================================================
   Tooltip + validation label
   ========================================================= */
QToolTip {
    background-color: #2a3748;
    color: #e6edf3;
    border: 1px solid #2a3748;
    padding: 4px 8px;
    border-radius: 4px;
}
QLabel#invalidLabel {
    color: #f97316;
    font-style: italic;
    font-size: 9pt;
}
</string>
